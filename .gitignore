# Claude Code local installation (generated from pro/ source files)
.claude/

# Eval outputs (generated, not tracked)
evals/outputs/
.DS_Store

# Local documentation (not published to GitHub by default)
# Uses glob form `docs/*` + `!docs/architecture/` + `docs/architecture/*` chain
# so the targeted whitelist below actually works (git won't re-include a file
# under an ignored parent directory — the intermediate un-ignore is required).
docs/*
!docs/architecture/
docs/architecture/*
# Whitelist: v1.7 architecture docs that ARE part of the release deliverable
# (navigated by v1.7-spec-map §1 reading order, referenced by CHANGELOG).
# Other docs/ content stays local-only until separately promoted.
!docs/architecture/v1.7-spec-map.md
!docs/architecture/system-overview.md

# Compliance incident archives (contain sanitized but sensitive context)
pro/compliance/*.md
!pro/compliance/violations.md
!pro/compliance/violations.example.md
# Whitelist: spec-violation and court-start incident dossiers (high info-density,
# long-term value, sanitized-safe — track in git so they travel with the repo).
!pro/compliance/*-spec-violation.md
!pro/compliance/*-court-*.md
!pro/compliance/*-incident-*.md

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local backup dir (from tools/backup.py tests)
backup/
